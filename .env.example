# Database (SQLite for demo, swap to Postgres for production)
# For demo: leave empty, SQLite is used automatically
# For production: DATABASE_URL=postgresql://user:pass@host:5432/dbname
DATABASE_URL=

# Auth (deferred — will be needed for NextAuth)
# NEXTAUTH_SECRET=your-secret-here
# NEXTAUTH_URL=http://localhost:3000

# Supabase (deferred — will be needed for image uploads + prod DB)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_KEY=your-service-key

# Scoring defaults
DEFAULT_THRESHOLD=7.0
STAR_THRESHOLD=8.5
LOW_SCORE_THRESHOLD=4.0
